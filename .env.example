# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token

# Notion
NOTION_TOKEN=ntn_your_token
NOTION_DATABASE_ID=your_database_id

# Яндекс.Диск (optional, for video)
YANDEX_DISK_TOKEN=

# Default hashtags (without #, comma-separated)
DEFAULT_HASHTAGS=завтраки,супы,выпечка,мясо,салаты,десерты,напитки,соусы,заготовки,другое

# Limits
MAX_VIDEO_SIZE_MB=500
VIDEO_QUALITY=1080
